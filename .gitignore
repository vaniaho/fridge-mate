# ==============================================================================
# ESP-IDF Smart Fridge Project .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# Build artifacts & ESP-IDF generated files
# ------------------------------------------------------------------------------
build/
**/build/
/build-*/
/out/
managed_components/
.idf_component_manager/
dependencies.lock.tmp
sdkconfig.old
# Note: sdkconfig is ignored as per ESP-IDF best practices since 
# sdkconfig.defaults is used to track project-specific configurations.
sdkconfig

# ------------------------------------------------------------------------------
# Compilation outputs
# ------------------------------------------------------------------------------
*.o
*.a
*.out
*.bin
*.elf
*.map
flasher_args.json

# ------------------------------------------------------------------------------
# Reference Projects
# ------------------------------------------------------------------------------
esp_brookesia_phone/

# ------------------------------------------------------------------------------
# CMake generated files
# ------------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
CMakeUserPresets.json

# ------------------------------------------------------------------------------
# Language Servers & IDEs
# ------------------------------------------------------------------------------
.clangd/
.ccls-cache/
.cache/
compile_commands.json
.vscode/
.idea/
*.user
*.workspace
*.suo
*.sln.docstates

# ------------------------------------------------------------------------------
# Local AI assistants and workspace metadata
# ------------------------------------------------------------------------------
.agents/
.codex/
.cursor/

# ------------------------------------------------------------------------------
# OS specific files
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ------------------------------------------------------------------------------
# Temporary & Log files
# ------------------------------------------------------------------------------
*~
*.swp
*.swo
*.bak
*.tmp
*.log

# ------------------------------------------------------------------------------
# Downloaded archives and local reference caches
# ------------------------------------------------------------------------------
downloads/

# ------------------------------------------------------------------------------
# Documentation - Developer C
# ------------------------------------------------------------------------------
doc/C 的开发路线.md

# ------------------------------------------------------------------------------
# Local secrets
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------------------------------------------
# Python (if any build scripts or venv are used)
# ------------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
venv/
.venv/
env/

# ------------------------------------------------------------------------------
# Node.js tooling
# ------------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
