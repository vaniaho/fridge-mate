# ==============================================================================
# ESP-IDF Smart Fridge Project .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# Build artifacts & ESP-IDF generated files
# ------------------------------------------------------------------------------
build/
**/build/
managed_components/
dependencies.lock.tmp
sdkconfig.old
# Note: sdkconfig is ignored as per ESP-IDF best practices since 
# sdkconfig.defaults is used to track project-specific configurations.
sdkconfig

# ------------------------------------------------------------------------------
# Compilation outputs
# ------------------------------------------------------------------------------
*.o
*.a
*.out
*.bin
*.elf
*.map
flasher_args.json

# ------------------------------------------------------------------------------
# Reference Projects
# ------------------------------------------------------------------------------
esp_brookesia_phone/

# ------------------------------------------------------------------------------
# CMake generated files
# ------------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake

# ------------------------------------------------------------------------------
# Language Servers & IDEs
# ------------------------------------------------------------------------------
.clangd/
.ccls-cache/
.cache/
compile_commands.json
.vscode/
.idea/
*.user
*.workspace
*.suo
*.sln.docstates

# ------------------------------------------------------------------------------
# OS specific files
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ------------------------------------------------------------------------------
# Temporary & Log files
# ------------------------------------------------------------------------------
*~
*.swp
*.swo
*.bak
*.tmp
*.log

# ------------------------------------------------------------------------------
# Documentation - Developer C
# ------------------------------------------------------------------------------
doc/C 的开发路线.md

# ------------------------------------------------------------------------------
# Python (if any build scripts or venv are used)
# ------------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.venv/
env/

