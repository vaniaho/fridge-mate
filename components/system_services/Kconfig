            string "Default Realtime Voice Model"
            default "1.2.1.1"

        config SMART_FRIDGE_DEFAULT_REALTIME_EXTRA
            string "Default Realtime Voice Extra Config"
            default "{\"appid\":\"\",\"resource_id\":\"volc.speech.dialog\",\"app_key\":\"PlgvMymc7f3tQnJ6\",\"speaker\":\"zh_female_vv_jupiter_bigtts\",\"input_mod\":\"keep_alive\"}"

        config AI_WORKER_STACK_SIZE
            int "AI Worker Task Stack Size"
            default 24576
            help
                Stack size for the AI worker task. LLM HTTPS calls need plenty of stack.

        config AI_WORKER_QUEUE_LEN
            int "AI Worker Queue Length"
            default 4
            help
                Maximum number of pending LLM requests.

        config AI_LLM_CONNECT_TIMEOUT_MS
            int "LLM Connect Timeout (ms)"
            default 10000
            help
                Timeout for establishing connection to LLM server.

        config AI_LLM_TOTAL_TIMEOUT_MS
            int "LLM Total Timeout (ms)"
            default 30000
            help
