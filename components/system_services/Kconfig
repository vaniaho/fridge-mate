menu "Smart Fridge Configuration"

    menu "WiFi Settings"
        config SMART_FRIDGE_DEFAULT_WIFI_SSID
            string "Default WiFi SSID"
            default ""
            help
                Default WiFi SSID. Can be overridden at runtime via NVS.

        config SMART_FRIDGE_DEFAULT_WIFI_PASS
            string "Default WiFi Password"
            default ""
            help
                Default WiFi password. Can be overridden at runtime via NVS.
    endmenu

    menu "Voice Model Settings"
        comment "ASR / LLM / TTS 三环节默认配置，provider 建议统一为 volcengine"

        config SMART_FRIDGE_DEFAULT_LLM_PROVIDER
            string "Default LLM Provider"
            default "volcengine"
            help
                Provider name, e.g. volcengine, baidu, moonshot, deepseek.

        config SMART_FRIDGE_DEFAULT_LLM_API_URL
            string "Default LLM API URL"
            default "https://ark.cn-beijing.volces.com/api/v3/chat/completions"
            help
                Default LLM API endpoint URL. Can be overridden at runtime via NVS.

        config SMART_FRIDGE_DEFAULT_LLM_API_KEY
            string "Default LLM API Key"
            default ""
            help
                Default LLM API key. Can be overridden at runtime via NVS.
                WARNING: Do not commit real API keys to version control.

        config SMART_FRIDGE_DEFAULT_LLM_MODEL
            string "Default LLM Model Name"
            default "doubao-seed-1.6-250615"
            help
                Default LLM model name used in API requests.

        config SMART_FRIDGE_DEFAULT_LLM_EXTRA
            string "Default LLM Extra Config"
            default ""
            help
                Extra config string, e.g. region, endpoint id.

        config SMART_FRIDGE_DEFAULT_ASR_PROVIDER
            string "Default ASR Provider"
            default "volcengine"
            help
                ASR provider name.

        config SMART_FRIDGE_DEFAULT_ASR_URL
            string "Default ASR API URL"
            default "wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async"
            help
                Default ASR endpoint URL.

        config SMART_FRIDGE_DEFAULT_ASR_KEY
            string "Default ASR API Key"
            default ""
            help
                Default ASR API key.

        config SMART_FRIDGE_DEFAULT_ASR_MODEL
            string "Default ASR Model"
            default "volc.bigasr.sauc.duration"
            help
                Default ASR model name.

        config SMART_FRIDGE_DEFAULT_ASR_EXTRA
            string "Default ASR Extra Config"
            default ""
            help
                Extra config for ASR, e.g. format=pcm, sample_rate=16000.

        config SMART_FRIDGE_DEFAULT_TTS_PROVIDER
            string "Default TTS Provider"
            default "volcengine"
